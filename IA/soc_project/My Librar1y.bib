@inproceedings{maniyat_integrated_2025,
	title = {An Integrated Knowledge Graph and Graph Neural Network Framework for Scalable Cyber Threat Attribution and Proactive Defense},
	url = {https://ieeexplore.ieee.org/document/11188397/},
	doi = {10.1109/NMITCON65824.2025.11188397},
	abstract = {This paper presents {ETRGNN}-{ZT}, a scalable and automated cybersecurity framework that integrates Neo4jbased knowledge graphs, Graph Neural Networks ({GNNs}) using the Deep Graph Library ({DGL}), and Zero-Trust ({ZT}) policy-driven mitigation. The proposed framework addresses key limitations of static security models by introducing a realtime pipeline for threat detection, risk prioritization, and proactive mitigation. Structured data from the {MITRE} {ATT}\&{CK} framework and unstructured Open Source Intelligence ({OSINT}) are fused to construct a dynamic knowledge graph representing attack tactics, vulnerabilities, and indicators of compromise ({IOCs}). The {GNN} module detects attack paths and generates threat scores, which drive automated {ZT} policy updates. Experimental evaluation demonstrates a detection accuracy of 96.7 \%, a mitigation success rate of 98.4 \%, and sub- 0.1 second inference latency, while maintaining linear scalability across millions of graph nodes. The {ETRGNN}-{ZT} framework offers an intelligent, resilient, and adaptive approach to modern cyber defense.},
	eventtitle = {2025 Third International Conference on Networks, Multimedia and Information Technology ({NMITCON})},
	pages = {1--6},
	booktitle = {2025 Third International Conference on Networks, Multimedia and Information Technology ({NMITCON})},
	author = {Maniyat, Vinod B and R, Arunkumar B},
	urldate = {2026-07-11},
	date = {2025-08},
	keywords = {Accuracy, Adaptive Security Solutions, Adaptive systems, Attack Path Detection, Auto mated Mitigation, Clustering, Cyber security Framework, Data Collection, Dynamic Policy Adjustment, Explainable {AI} ({XAI}), Graph neural networks, Graph Neural Networks ({GNNs}), {IoT} Threats, Knowledge Graph, Knowledge graphs, Link Prediction, Network Vulnerabilities, Node Classification, Prevention and mitigation, Proactive Defense, Real-Time Response, Real-time systems, Risk Assessment, Scalability, Telemetry, Threat Analysis, Threat assessment, Visual analytics, Visual Analytics, Zero-Trust Policies},
	file = {Full Text PDF:C\:\\Users\\USUARIO\\Zotero\\storage\\5G3HKGZ4\\Maniyat and R - 2025 - An Integrated Knowledge Graph and Graph Neural Network Framework for Scalable Cyber Threat Attributi.pdf:application/pdf},
}

