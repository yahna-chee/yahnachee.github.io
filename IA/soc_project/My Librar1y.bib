
@inproceedings{goud_semi-supervised_2026,
	title = {A Semi-Supervised and Evasion-Aware Framework for Reducing Alert Fatigue in Security Operations Centers ({SoC})},
	url = {https://ieeexplore.ieee.org/document/11502746/},
	doi = {10.1109/ICICCS67901.2026.11502746},
	abstract = {Security Operations Centers often depend on automated detection tools that produce many alerts, most of which reflect normal, non-malicious activity. This situation can cause alert fatigue, increase analysts' workload, and raise the risk that genuine attacks go unnoticed. Machine-learning alert triage systems may help sort and prioritize alerts, yet their performance often suffers when there are too few labeled examples, when patterns change over time, and when attackers adapt their behavior to avoid detection. This paper proposes a semisupervised, risk-aware approach to {SOC} alert triage that accounts for practical operational constraints. This method combines a hybrid source-target labeling scheme with rankbased tri-training and probabilistic calibration to learn from large amounts of unlabeled alert data while keeping attack recall as the main objective. Risk-aware decision thresholds are set so the system can close alerts conservatively while avoiding an increase in false negatives. We used temporally split network flow data from the {CI}-{CIDS}2017 dataset to simulate {SOC} alert streams. The experiments show that supervised models lose a large amount of recall when the data shift over time. In contrast, the proposed semi-supervised framework reduces this recall drop and supports automatic closure of many benign alerts. A proof-of-concept integration with the Wazuh {SIEM} platform was conducted to examine practical issues and constraints related to deployment. The results suggest that semi-supervised, risk-sensitive learning can reduce alert fatigue while preserving detection performance in dynamic and adversarial {SOC} settings.},
	eventtitle = {2026 9th International Conference on Intelligent Computing and Control Systems ({ICICCS})},
	pages = {2007--2013},
	booktitle = {2026 9th International Conference on Intelligent Computing and Control Systems ({ICICCS})},
	author = {Goud, Kalimera Nandu and Jain, Kurunandan and Krishnan, Prabhakar},
	urldate = {2026-07-11},
	date = {2026-03},
	keywords = {Adversarial Evasion, Alert Fatigue, Application specific integrated circuits, Circuits, Communication systems, Concept Drift, Feedback, Guns, Internet, Intrusion Detection, Millimeter wave integrated circuits, {MIMICs}, Monolithic integrated circuits, Security Operations Center ({SOC}), Semi-Supervised Learning, System-on-chip},
	file = {Full Text PDF:C\:\\Users\\USUARIO\\Zotero\\storage\\S3JVS5XY\\Goud et al. - 2026 - A Semi-Supervised and Evasion-Aware Framework for Reducing Alert Fatigue in Security Operations Cent.pdf:application/pdf},
}

@inproceedings{priyanka_large_2026,
	title = {Large Language Model {SOC} Automation: Future Opportunity and Threats of {AI}-Approved Defense},
	url = {https://ieeexplore.ieee.org/document/11484758/},
	doi = {10.1109/ETFI68128.2026.11484758},
	shorttitle = {Large Language Model {SOC} Automation},
	abstract = {The recent fast development of the Large Language Models ({LLMs}) has provided some major opportunities to automate and optimize the work of the Security Operations Centers ({SOCs}) activity. This paper discusses the potential transformational aspect of {LLMs} in enhancing the efficiency of the cyber security defensive measures, such as the creation of threat intelligence, automatic threat event tent rage, logic management approach and adversarial behavior detection. Since the capabilities of the natural language processor are used in models like {GPT}-4 among others, {SOC} teams have gained an opportunity to improve rapid response, burnout of curb analysts, and, accordingly, simplified modalities of choice. However, there are also varied technical, operational, and ethical threats tied to the use of the {LLM} with major security infrastructure. These are model hallucination, adversarial prompting, data leakage, as well as overreliance on opaque outputs. The article provides a critical evaluation of such dualities, charting the advantages of {AI}-enhanced defense in terms of its possible flaws. The hybrid human-{AI} structure is suggested as a necessary measure to guarantee prosperous monitoring, transparency and flexibility in the {SOC} environments. The results support the need to exercise tremendous care during deployment, thoroughly analyze, and harmonize policies to ensure the maximum value of {LLMs} in the cyber security operation today.},
	eventtitle = {2026 International Conference on Emerging Technologies and Future Innovations ({ETFI})},
	pages = {1--5},
	booktitle = {2026 International Conference on Emerging Technologies and Future Innovations ({ETFI})},
	author = {Priyanka, Parankusham and Glory, Bangi and Abhilasha, Chava and Jasmini, Etukala and Preethi, Gunda and Nikhitha, Male},
	urldate = {2026-07-11},
	date = {2026-02},
	keywords = {{AI} augmented defense, Antennas, Application specific integrated circuits, Circuits, Circuits and systems, Communication systems, cyber security, Feedback, Feeds, Filtering, Filters, {LLM} (large language models), security operations centres ({SOC}), {SOC}, System-on-chip},
	file = {Full Text PDF:C\:\\Users\\USUARIO\\Zotero\\storage\\VKS6WVMZ\\Priyanka et al. - 2026 - Large Language Model SOC Automation Future Opportunity and Threats of AI-Approved Defense.pdf:application/pdf},
}

@inproceedings{mcelwee_deep_2017,
	title = {Deep learning for prioritizing and responding to intrusion detection alerts},
	issn = {2155-7586},
	url = {https://ieeexplore.ieee.org/document/8170757/},
	doi = {10.1109/MILCOM.2017.8170757},
	abstract = {Network intrusion detection systems are widely deployed to detect cyberattacks against computer networks. These systems generate large numbers of security alerts that require manual review by security analysts to determine the appropriate courses of action required. The review of these security alerts is time consuming and can cause fatigue for security analysts, especially during long work shifts. This paper reviews a case study of the application of machine learning to the initial triage of security alerts to help reduce the manual burden placed on Department of Defense ({DOD}) cyber defense security analysts. This study implemented a Federated Analysis Security Triage Tool prototype. The {FASTT} prototype attempted to highlight, summarize and categorize tens of thousands of daily alerts/events. The prototype integrated a number of tools including {TensorFlow} deep neural network classifier, Elasticsearch and Kibana to provide an alternative approach for cyber defense analysts. {FASTT} provides a quick way to perform security alert reviews, speed up analyst queries/response, and to semi-automate threat intelligence reporting. The results of this study were evaluated for accuracy and usability. Results demonstrated that the accuracy of a deep neural network classifier was very high, as it was able to determine the heuristics that the cyber defense security analysts used in their review. Demonstrations and interviews with the security analysts showed that the prototype was able to quickly categorize security alerts into meaningful categories, provide fast query of the alerts, and save time in generating reports. Lastly, {FASTT} was able to pull the necessary information to generate Indications of Compromise ({IOC}) in a {STIX}/{TAXII} format that could be shared across {DOD} and {US} Government.},
	eventtitle = {{MILCOM} 2017 - 2017 {IEEE} Military Communications Conference ({MILCOM})},
	pages = {1--5},
	booktitle = {{MILCOM} 2017 - 2017 {IEEE} Military Communications Conference ({MILCOM})},
	author = {{McElwee}, Steven and Heaton, Jeffrey and Fraley, James and Cannady, James},
	urldate = {2026-07-11},
	date = {2017-10},
	note = {{ISSN}: 2155-7586},
	keywords = {deep learning, Feature extraction, Intrusion defense, Intrusion detection, neural network, Neural networks, Pipelines, Prototypes, security analysis, User interfaces},
	file = {Full Text PDF:C\:\\Users\\USUARIO\\Zotero\\storage\\XH272T4C\\McElwee et al. - 2017 - Deep learning for prioritizing and responding to intrusion detection alerts.pdf:application/pdf},
}

@inproceedings{sharbaf_reengineering_2026,
	title = {Reengineering Cybersecurity Processes with Generative {AI}: From Automation to Strategic Alignment},
	url = {https://ieeexplore.ieee.org/document/11395839/},
	doi = {10.1109/ICAIC67076.2026.11395839},
	shorttitle = {Reengineering Cybersecurity Processes with Generative {AI}},
	abstract = {Generative {AI} is rapidly transforming enterprise operations, yet its applicability to cybersecurity beyond automation remains limited. This paper presents a strategic framework to embed generative {AI} within the reengineering of cybersecurity processes, transitioning from reactive and compliance-driven paradigms to proactive, quality-managed systems. We discuss how generative {AI} can enhance the translation of complex frameworks, improve stakeholder alignment, and accelerate continuous improvement. Through technical applications and real-world examples, we demonstrate that generative {AI} can elevate cybersecurity maturity, optimize workflows, and bolster strategic resilience.},
	eventtitle = {2026 {IEEE} 5th International Conference on {AI} in Cybersecurity ({ICAIC})},
	pages = {1--4},
	booktitle = {2026 {IEEE} 5th International Conference on {AI} in Cybersecurity ({ICAIC})},
	author = {Sharbaf, Mehrdad S.},
	urldate = {2026-07-11},
	date = {2026-02},
	keywords = {Automation, Computer security, Continuous improvement, Cybersecurity Process Reengineering, Generative {AI}, Governance, {ISO}, Maturity Assessment, {NIST}, Quality management, Quality Management, Resilience, Role Alignment, {SOC}, Stakeholders, Translation, Visual communication, Visual Communication},
	file = {Full Text PDF:C\:\\Users\\USUARIO\\Zotero\\storage\\8R7MZ6LB\\Sharbaf - 2026 - Reengineering Cybersecurity Processes with Generative AI From Automation to Strategic Alignment.pdf:application/pdf},
