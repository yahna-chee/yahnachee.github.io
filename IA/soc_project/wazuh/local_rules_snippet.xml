<!--
  Ejemplo ilustrativo de reglas locales de Wazuh equivalentes a los patrones descritos en
  sigma_rules/phishing_office_macro_execution.yml y sigma_rules/privesc_suspicious_elevation.yml.

  Este archivo es un PUNTO DE PARTIDA para adaptar manualmente o para comparar contra la salida
  real de `sigma convert -t wazuh ...` (ver wazuh/README_wazuh_setup.md, seccion 3).
  Colocar dentro de <group> en /var/ossec/etc/rules/local_rules.xml del manager.
-->
<group name="local,phishing,privilege_escalation,">

  <!-- T1566.001 / T1204.002 - Office generando un proceso hijo tipo shell o script -->
  <rule id="100010" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(WINWORD|EXCEL|POWERPNT|OUTLOOK)\.EXE$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd|powershell|pwsh|wscript|cscript|mshta|rundll32)\.exe$</field>
    <description>Posible ejecucion de payload de phishing: Office genero un proceso hijo sospechoso (T1566.001, T1204.002)</description>
    <mitre>
      <id>T1566.001</id>
      <id>T1204.002</id>
    </mitre>
  </rule>

  <!-- T1548.001 / T1548.002 - Abuso de mecanismos de elevacion de privilegios en Windows -->
  <rule id="100011" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(fodhelper|sdclt|eventvwr)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)explorer\.exe$</field>
    <description>Posible bypass de UAC / elevacion de privilegios via utilidad legitima abusada (T1548.001)</description>
    <mitre>
      <id>T1548.001</id>
    </mitre>
  </rule>

  <!-- T1548.001 - PwnKit / abuso de pkexec en Linux -->
  <rule id="100012" level="12">
    <if_sid>2501</if_sid>
    <match>pkexec</match>
    <match>XAUTHORITY</match>
    <description>Posible explotacion de escalada de privilegios local vía pkexec (T1548.001, patron tipo PwnKit)</description>
    <mitre>
      <id>T1548.001</id>
    </mitre>
  </rule>

</group>
